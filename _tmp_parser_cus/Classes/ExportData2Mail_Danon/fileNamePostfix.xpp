public Filename fileNamePostfix()
{
    Filename   ret;
    ;

    ret = date2str(transDate, 321, DateDay::Digits2, DateSeparator::None, DateMonth::Digits2, DateSeparator::None, DateYear::Digits4) + "_";
    ret += strRem(time2str(DateTimeUtil::time(DateTimeUtil::getSystemDateTime()), TimeSeparator::Colon, TimeSeparator::Colon), ":");

    return ret;
}