      SOURCE #validateBudgetReservation_PSN
        #/// <summary>
        #/// Performs validations on the <c>BudgetReservationLine_PSN</c> field of each <c>PurchLine</c> line record associated
        #/// with the specified <c>PurchTable</c> record.
